# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (Required for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_SINGLE=price_... # Single tier $29/mo
STRIPE_PRICE_MULTI=price_...  # Multi tier $79/mo
STRIPE_PRICE_PRO=price_...    # Pro tier $149/mo

# Anthropic Claude (Required for AI features)
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (Required for user signup/login)
# Get these from Google Cloud Console OAuth credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# App URL (Required)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Places API (Required for free audit tool)
# Create in Google Cloud Console with Places API (New) enabled
GOOGLE_PLACES_API_KEY=your-places-api-key

# Cron Secret (Required for cron jobs)
CRON_SECRET=your-random-secret-string
